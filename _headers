/index.html
  Cache-Control: no-store

/*.html
  Cache-Control: no-store

# JS/CSS are versioned with a "?v=" query string in index.html, so it is
# safe to let browsers cache them for a long time. When the version bumps,
# the URL changes and the old cached copy is simply ignored.
/js/*
  Cache-Control: public, max-age=31536000, immutable

/style.css
  Cache-Control: public, max-age=31536000, immutable

# Icons and team logos rarely change, so a shorter but still long cache
# avoids re-downloading them on every repeat visit.
/icons/*
  Cache-Control: public, max-age=604800

/TeamLogo/*
  Cache-Control: public, max-age=604800

/manifest.json
  Cache-Control: public, max-age=86400